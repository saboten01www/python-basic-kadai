      "source": [
        "def calculate_tax(price, tax_rate):\n",
        "    # 商品金額に消費税率をかけて計算する\n",
        "    # 10%は「10 / 100」で計算できます\n",
        "    tax_amount = price * (tax_rate / 100)\n",
        "    total_price = price + tax_amount\n",
        "    return total_price\n",
        "\n",
        "# 関数の呼び出し（第1引数：110、第2引数：10）\n",
        "result = calculate_tax(110, 10)\n",
        "\n",
        "# 結果の表示\n",
        "print(result)"
      ]
    }
  ]
